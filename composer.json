{
  "name": "luremo/craft-link-migrator",
  "description": "Staged migration plugin for moving Verbb Hyper fields and content to Craft's native Link field with audit, prepare, content, and finalize workflows.",
  "type": "craft-plugin",
  "keywords": [
    "craftcms",
    "craft-plugin",
    "migration",
    "hyper",
    "link",
    "cli"
  ],
  "license": "proprietary",
  "authors": [
    {
      "name": "Luremo",
      "homepage": "https://github.com/LuremoDigital"
    }
  ],
  "homepage": "https://github.com/LuremoDigital/Link-migration",
  "support": {
    "issues": "https://github.com/LuremoDigital/Link-migration/issues",
    "source": "https://github.com/LuremoDigital/Link-migration",
    "docs": "https://github.com/LuremoDigital/Link-migration/blob/main/README.md",
    "rss": "https://github.com/LuremoDigital/Link-migration/commits/main.atom"
  },
  "require": {
    "php": "^8.2",
    "craftcms/cms": "^5.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "luremo\\linkmigrator\\": "src/"
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "config": {
    "allow-plugins": {
      "craftcms/plugin-installer": true,
      "yiisoft/yii2-composer": true
    }
  },
  "extra": {
    "name": "Link Migrator",
    "handle": "link-migrator",
    "description": "Staged migration plugin for moving Verbb Hyper fields and content to Craft's native Link field safely.",
    "class": "luremo\\linkmigrator\\LinkMigrator",
    "schemaVersion": "1.2.0",
    "developer": "Luremo",
    "developerUrl": "https://github.com/LuremoDigital",
    "documentationUrl": "https://github.com/LuremoDigital/Link-migration/blob/main/README.md",
    "changelogUrl": "https://raw.githubusercontent.com/LuremoDigital/Link-migration/main/CHANGELOG.md"
  }
}
