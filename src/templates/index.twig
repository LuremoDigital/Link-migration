{% extends "_layouts/cp" %}

{% set title = "Link Migrator" %}
{% set pluginCpUrl = url('link-migrator') %}
{% set mismatchCount = audit.mismatchReferences|length %}
{% set totalFields = statuses|length %}
{% set migratableCount = statuses|filter(s => s.mappingStatus != 'unsupported')|length %}
{% set preparedCount = statuses|filter(s => s.phase != 'audited')|length %}
{% set readyCount = statuses|filter(s => s.phase in ['readyToFinalize', 'finalized'])|length %}
{% set finalizedCount = statuses|filter(s => s.phase == 'finalized')|length %}
{% set issueCount = audit.fields|filter(f => f.warnings|length > 0)|length %}

{% set phaseLabels = {
  audited: 'Audited',
  prepared: 'Prepared',
  contentMigrated: 'Content migrated',
  readyToFinalize: 'Ready to finalize',
  finalized: 'Finalized',
} %}
{% set phaseColors = {
  audited: '',
  prepared: 'orange',
  contentMigrated: 'orange',
  readyToFinalize: 'green',
  finalized: 'green',
} %}

{% block content %}
  <div class="readable">
    <p>
      This wizard keeps Hyper fields intact, prepares parallel native Link fields, migrates content in batches, and only cuts field layouts over during the final step.
    </p>

    {% if totalFields == 0 %}
      <div class="zilch">
        <p>No Hyper fields detected.</p>
      </div>
    {% else %}
      <h2>Migration steps</h2>

      <div class="pane">
        <h3>1. Audit <span class="status green"></span></h3>
        <p>{{ totalFields }} Hyper field(s) detected. Auditing is read-only and re-runs on every page load.</p>
        {% if issueCount > 0 or mismatchCount > 0 %}
          <p class="warning">
            Potential issues found: {{ issueCount }} field warning(s), {{ mismatchCount }} template mismatch(es).
          </p>
        {% endif %}
        <a class="btn" href="{{ pluginCpUrl }}">Refresh audit</a>
      </div>

      <div class="pane">
        <h3>2. Prepare native fields
          {% if migratableCount > 0 and preparedCount == migratableCount %}<span class="status green"></span>{% endif %}
        </h3>
        <p>
          Creates native Link fields and inserts them next to the source fields in layouts.
          <strong>{{ preparedCount }} of {{ migratableCount }} prepared.</strong>
        </p>
        <form method="post" onsubmit="return confirm('Create native Link fields and update layouts?');">
          {{ csrfInput() }}
          {{ actionInput('link-migrator/wizard/prepare-fields') }}
          <label><input type="checkbox" name="force" value="1"> I understand this writes fields and layouts</label>
          <div class="buttons" style="margin-top: 12px;">
            <button class="btn submit">Prepare native fields</button>
          </div>
        </form>
      </div>

      <div class="pane">
        <h3>3. Migrate content
          {% if migratableCount > 0 and readyCount == migratableCount %}<span class="status green"></span>{% endif %}
        </h3>
        <p>
          Copies Hyper values into prepared native fields, writes backups, and re-checks saved values.
          <strong>{{ readyCount }} of {{ migratableCount }} verified and ready to finalize.</strong>
        </p>
        <form method="post" onsubmit="return confirm('Write native Link content with backups?');">
          {{ csrfInput() }}
          {{ actionInput('link-migrator/wizard/migrate-content') }}
          <label><input type="checkbox" name="force" value="1"> I understand this writes content</label>
          <div class="buttons" style="margin-top: 12px;">
            <button class="btn submit">Migrate content</button>
          </div>
        </form>
      </div>

      <div class="pane">
        <h3>4. Review template impact
          {% if mismatchCount == 0 %}<span class="status green"></span>{% endif %}
        </h3>
        {% if mismatchCount > 0 %}
          <p class="warning">
            {{ mismatchCount }} potential Hyper API usage(s) found. These can break after finalize.
          </p>
          <details>
            <summary class="btn">Show mismatches</summary>
            <table class="data fullwidth" style="margin-top: 12px;">
              <thead>
                <tr>
                  <th>File</th>
                  <th>Line</th>
                  <th>Change</th>
                  <th>Snippet</th>
                </tr>
              </thead>
              <tbody>
                {% for mismatch in audit.mismatchReferences %}
                  <tr>
                    <td><code>{{ mismatch.file }}</code></td>
                    <td>{{ mismatch.line }}</td>
                    <td>
                      <code>{{ mismatch.pattern }}</code> → <code>{{ mismatch.replacement }}</code>
                      <div class="light">{{ mismatch.reason }}</div>
                    </td>
                    <td><code>{{ mismatch.snippet }}</code></td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </details>
        {% else %}
          <p>No Hyper-only API usage found in templates or modules.</p>
        {% endif %}
        <p class="light">
          Common changes:
          <code>.text</code> becomes <code>.label</code>,
          <code>getElement()</code> becomes <code>.element</code>,
          Hyper class checks become native type handles.
        </p>
      </div>

      <div class="pane">
        <h3>5. Finalize
          {% if migratableCount > 0 and finalizedCount == migratableCount %}<span class="status green"></span>{% endif %}
        </h3>
        <p>
          Removes Hyper fields from layouts only after live content is verified. Hyper fields themselves are not deleted.
        </p>
        <form method="post" onsubmit="return confirm('Remove Hyper fields from field layouts?');">
          {{ csrfInput() }}
          {{ actionInput('link-migrator/wizard/finalize') }}
          <label><input type="checkbox" name="force" value="1"> I understand this changes field layouts</label>
          {% if mismatchCount > 0 %}
            <br>
            <label><input type="checkbox" name="acknowledgeMismatches" value="1"> I reviewed the {{ mismatchCount }} template mismatch(es)</label>
          {% endif %}
          <div class="buttons" style="margin-top: 12px;">
            <button class="btn submit">Finalize cutover</button>
          </div>
        </form>
      </div>
    {% endif %}

    <h2>Workflow status</h2>
    <table class="data fullwidth">
      <thead>
        <tr>
          <th>Source</th>
          <th>Native target</th>
          <th>Phase</th>
          <th>Mapping</th>
          <th>Content</th>
        </tr>
      </thead>
      <tbody>
        {% for status in statuses %}
          {% set content = status.contentSummary ?? {} %}
          {% set warnings = content.warningCount ?? 0 %}
          {% set errors = content.errorCount ?? 0 %}
          <tr>
            <td>{{ status.sourceHandle }}</td>
            <td>{{ status.targetHandle ?? 'Not prepared' }}</td>
            <td><span class="status {{ phaseColors[status.phase] ?? '' }}"></span>{{ phaseLabels[status.phase] ?? status.phase }}</td>
            <td>{{ status.mappingStatus }}</td>
            <td>
              migrated={{ content.migratedCount ?? 0 }},
              skipped={{ content.skippedCount ?? 0 }},
              empty={{ content.skippedEmptyCount ?? 0 }},
              already migrated={{ content.skippedAlreadyMigratedCount ?? 0 }},
              already native={{ content.skippedAlreadyNativeCount ?? 0 }},
              other skipped={{ content.skippedOtherCount ?? 0 }},
              warnings={{ warnings }},
              errors={{ errors }}
              {% if warnings > 0 or errors > 0 %}
                <div class="warning">Review warnings/errors before finalizing.</div>
              {% endif %}
            </td>
          </tr>
        {% else %}
          <tr>
            <td colspan="5">No Hyper fields detected.</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>

    <h2>Template impact review</h2>
    <p>Review the CLI mismatch report before finalizing. This release does not rewrite templates automatically.</p>
    <ul>
      <li><code>.text</code> becomes <code>.label</code></li>
      <li><code>getElement()</code> becomes <code>.element</code></li>
      <li>Hyper class-name type checks become native short handles like <code>entry</code> or <code>url</code></li>
    </ul>
  </div>
{% endblock %}
