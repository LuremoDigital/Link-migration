{% extends "_layouts/cp" %}

{% set title = 'Link Migrator'|t('link-migrator') %}
{% set pluginCpUrl = url('link-migrator') %}
{% set mismatchCount = audit.mismatchReferences|length %}
{% set totalFields = statuses|length %}
{% set migratableCount = statuses|filter(s => s.mappingStatus != 'unsupported')|length %}
{% set preparedCount = statuses|filter(s => s.phase != 'audited')|length %}
{% set readyCount = statuses|filter(s => s.phase in ['readyToFinalize', 'finalized'])|length %}
{% set finalizedCount = statuses|filter(s => s.phase == 'finalized')|length %}
{% set issueCount = audit.fields|filter(f => f.warnings|length > 0)|length %}

{% set phaseLabels = {
  audited: 'Audited'|t('link-migrator'),
  prepared: 'Prepared'|t('link-migrator'),
  contentMigrated: 'Content migrated'|t('link-migrator'),
  readyToFinalize: 'Ready to finalize'|t('link-migrator'),
  finalized: 'Finalized'|t('link-migrator'),
} %}
{% set phaseColors = {
  audited: '',
  prepared: 'orange',
  contentMigrated: 'orange',
  readyToFinalize: 'green',
  finalized: 'green',
} %}

{% block content %}
  <div class="readable">
    <p>
      {{ 'This wizard keeps Hyper fields intact, prepares parallel native Link fields, migrates content in batches, and only cuts field layouts over during the final step.'|t('link-migrator') }}
    </p>
    <p class="light">
      {{ 'Link Migrator is free to use in local, development, staging, and production environments.'|t('link-migrator') }}
    </p>

    {% if totalFields == 0 %}
      <div class="zilch">
        <p>{{ 'No Hyper fields detected.'|t('link-migrator') }}</p>
      </div>
    {% else %}
      <h2>{{ 'Migration steps'|t('link-migrator') }}</h2>

      <div class="pane">
        <h3>1. {{ 'Audit'|t('link-migrator') }} <span class="status green"></span></h3>
        <p>{{ '{total} Hyper field(s) detected. Auditing is read-only and re-runs on every page load.'|t('link-migrator', { total: totalFields }) }}</p>
        {% if issueCount > 0 or mismatchCount > 0 %}
          <p class="warning">
            {{ 'Potential issues found: {issues} field warning(s), {mismatches} template mismatch(es).'|t('link-migrator', { issues: issueCount, mismatches: mismatchCount }) }}
          </p>
        {% endif %}
        <a class="btn" href="{{ pluginCpUrl }}">{{ 'Refresh audit'|t('link-migrator') }}</a>
      </div>

      <div class="pane">
        <h3>2. {{ 'Prepare native fields'|t('link-migrator') }}
          {% if migratableCount > 0 and preparedCount == migratableCount %}<span class="status green"></span>{% endif %}
        </h3>
        <p>
          {{ 'Creates native Link fields and inserts them next to the source fields in layouts.'|t('link-migrator') }}
          <strong>{{ '{prepared} of {total} prepared.'|t('link-migrator', { prepared: preparedCount, total: migratableCount }) }}</strong>
        </p>
        <form method="post" onsubmit="return confirm({{ 'Create native Link fields and update layouts?'|t('link-migrator')|json_encode|raw }});">
          {{ csrfInput() }}
          {{ actionInput('link-migrator/wizard/prepare-fields') }}
          <label><input type="checkbox" name="force" value="1"> {{ 'I understand this writes fields and layouts'|t('link-migrator') }}</label>
          <div class="buttons" style="margin-top: 12px;">
            <button class="btn submit">{{ 'Prepare native fields'|t('link-migrator') }}</button>
          </div>
        </form>
      </div>

      <div class="pane">
        <h3>3. {{ 'Migrate content'|t('link-migrator') }}
          {% if migratableCount > 0 and readyCount == migratableCount %}<span class="status green"></span>{% endif %}
        </h3>
        <p>
          {{ 'Copies Hyper values into prepared native fields, writes backups, and re-checks saved values.'|t('link-migrator') }}
          <strong>{{ '{ready} of {total} verified and ready to finalize.'|t('link-migrator', { ready: readyCount, total: migratableCount }) }}</strong>
        </p>
        <form method="post" onsubmit="return confirm({{ 'Write native Link content with backups?'|t('link-migrator')|json_encode|raw }});">
          {{ csrfInput() }}
          {{ actionInput('link-migrator/wizard/migrate-content') }}
          <label><input type="checkbox" name="force" value="1"> {{ 'I understand this writes content'|t('link-migrator') }}</label>
          <div class="buttons" style="margin-top: 12px;">
            <button class="btn submit">{{ 'Migrate content'|t('link-migrator') }}</button>
          </div>
        </form>
      </div>

      <div class="pane">
        <h3>4. {{ 'Review template impact'|t('link-migrator') }}
          {% if mismatchCount == 0 %}<span class="status green"></span>{% endif %}
        </h3>
        {% if mismatchCount > 0 %}
          <p class="warning">
            {{ '{count} potential Hyper API usage(s) found. These can break after finalize.'|t('link-migrator', { count: mismatchCount }) }}
          </p>
          <details>
            <summary class="btn">{{ 'Show mismatches'|t('link-migrator') }}</summary>
            <table class="data fullwidth" style="margin-top: 12px;">
              <thead>
                <tr>
                  <th>{{ 'File'|t('link-migrator') }}</th>
                  <th>{{ 'Line'|t('link-migrator') }}</th>
                  <th>{{ 'Change'|t('link-migrator') }}</th>
                  <th>{{ 'Snippet'|t('link-migrator') }}</th>
                </tr>
              </thead>
              <tbody>
                {% for mismatch in audit.mismatchReferences %}
                  <tr>
                    <td><code>{{ mismatch.file }}</code></td>
                    <td>{{ mismatch.line }}</td>
                    <td>
                      <code>{{ mismatch.pattern }}</code> → <code>{{ mismatch.replacement }}</code>
                      <div class="light">{{ mismatch.reason }}</div>
                    </td>
                    <td><code>{{ mismatch.snippet }}</code></td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </details>
        {% else %}
          <p>{{ 'No Hyper-only API usage found in templates or modules.'|t('link-migrator') }}</p>
        {% endif %}
        <p class="light">
          {{ 'Common changes:'|t('link-migrator') }}
          <code>.text</code> {{ 'becomes'|t('link-migrator') }} <code>.label</code>,
          <code>getElement()</code> {{ 'becomes'|t('link-migrator') }} <code>.element</code>,
          {{ 'Hyper class checks become native type handles.'|t('link-migrator') }}
        </p>
      </div>

      <div class="pane">
        <h3>5. {{ 'Finalize'|t('link-migrator') }}
          {% if migratableCount > 0 and finalizedCount == migratableCount %}<span class="status green"></span>{% endif %}
        </h3>
        <p>
          {{ 'Removes Hyper fields from layouts only after live content is verified. Hyper fields themselves are not deleted.'|t('link-migrator') }}
        </p>
        <p class="light">
          {{ 'The Finalize step changes field layouts, so review your templates, backups, and reports before continuing.'|t('link-migrator') }}
        </p>
        <form method="post" onsubmit="return confirm({{ 'Remove Hyper fields from field layouts?'|t('link-migrator')|json_encode|raw }});">
          {{ csrfInput() }}
          {{ actionInput('link-migrator/wizard/finalize') }}
          <label><input type="checkbox" name="force" value="1"> {{ 'I understand this changes field layouts'|t('link-migrator') }}</label>
          {% if mismatchCount > 0 %}
            <br>
            <label><input type="checkbox" name="acknowledgeMismatches" value="1"> {{ 'I reviewed the {count} template mismatch(es)'|t('link-migrator', { count: mismatchCount }) }}</label>
          {% endif %}
          <div class="buttons" style="margin-top: 12px;">
            <button class="btn submit">{{ 'Finalize cutover'|t('link-migrator') }}</button>
          </div>
        </form>
      </div>
    {% endif %}

    <h2>{{ 'Workflow status'|t('link-migrator') }}</h2>
    <table class="data fullwidth">
      <thead>
        <tr>
          <th>{{ 'Source'|t('link-migrator') }}</th>
          <th>{{ 'Native target'|t('link-migrator') }}</th>
          <th>{{ 'Phase'|t('link-migrator') }}</th>
          <th>{{ 'Mapping'|t('link-migrator') }}</th>
          <th>{{ 'Content'|t('link-migrator') }}</th>
        </tr>
      </thead>
      <tbody>
        {% for status in statuses %}
          {% set content = status.contentSummary ?? {} %}
          {% set warnings = content.warningCount ?? 0 %}
          {% set errors = content.errorCount ?? 0 %}
          <tr>
            <td>{{ status.sourceHandle }}</td>
            <td>
              {% if status.targetHandle %}
                {{ status.targetHandle }}
              {% else %}
                {{ 'Not prepared'|t('link-migrator') }}
              {% endif %}
            </td>
            <td><span class="status {{ phaseColors[status.phase] ?? '' }}"></span>{{ phaseLabels[status.phase] ?? status.phase }}</td>
            <td>{{ status.mappingStatus }}</td>
            <td>
              {{ 'migrated={count}'|t('link-migrator', { count: content.migratedCount ?? 0 }) }},
              {{ 'skipped={count}'|t('link-migrator', { count: content.skippedCount ?? 0 }) }},
              {{ 'empty={count}'|t('link-migrator', { count: content.skippedEmptyCount ?? 0 }) }},
              {{ 'already migrated={count}'|t('link-migrator', { count: content.skippedAlreadyMigratedCount ?? 0 }) }},
              {{ 'already native={count}'|t('link-migrator', { count: content.skippedAlreadyNativeCount ?? 0 }) }},
              {{ 'other skipped={count}'|t('link-migrator', { count: content.skippedOtherCount ?? 0 }) }},
              {{ 'warnings={count}'|t('link-migrator', { count: warnings }) }},
              {{ 'errors={count}'|t('link-migrator', { count: errors }) }}
              {% if warnings > 0 or errors > 0 %}
                <div class="warning">{{ 'Review warnings/errors before finalizing.'|t('link-migrator') }}</div>
              {% endif %}
            </td>
          </tr>
        {% else %}
          <tr>
            <td colspan="5">{{ 'No Hyper fields detected.'|t('link-migrator') }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>

    <h2>{{ 'Template impact review'|t('link-migrator') }}</h2>
    <p>{{ 'Review the CLI mismatch report before finalizing. This release does not rewrite templates automatically.'|t('link-migrator') }}</p>
    <ul>
      <li><code>.text</code> {{ 'becomes'|t('link-migrator') }} <code>.label</code></li>
      <li><code>getElement()</code> {{ 'becomes'|t('link-migrator') }} <code>.element</code></li>
      <li>{{ 'Hyper class-name type checks become native short handles like'|t('link-migrator') }} <code>entry</code> {{ 'or'|t('link-migrator') }} <code>url</code></li>
    </ul>
  </div>
{% endblock %}
